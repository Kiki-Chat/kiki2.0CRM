# Secrets + local env — MUST be excluded, especially with `railway up --no-gitignore`
# (filesystem upload, used because this is a git worktree and the git-based upload ships
# a stale snapshot). .gitignore does NOT protect these here. Railway service variables
# provide config at runtime; a baked frontend .env.local would break the prod build.
.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.local
frontend/.env.*.local

