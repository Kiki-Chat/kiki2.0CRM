# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# HeyKiki provisioning
MASTER_WEBHOOK_SECRET=change-me
# Shared secret for the N8N -> backend post-call webhook hop
POST_CALL_WEBHOOK_SECRET=change-me

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# ElevenLabs (used in later phases)
ELEVENLABS_API_KEY=

# Secret-at-rest encryption for stored SMTP/PDS credentials (REQUIRED — backend refuses to start without it).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENC_KEY=<run-python-c-from-cryptography-fernet-import-Fernet-print-Fernet-generate-key-decode>

# OAuth (P1.8) — paste real values from Google Cloud Console / Azure App Registration
# per P1.8_OAUTH_SETUP.md once you've registered the HeyKiki Portal apps.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
# Public URL the OAuth providers redirect back to (must match the registered redirect URIs).
BACKEND_PUBLIC_URL=http://localhost:8000
# Public base URL of the CRM frontend — used for EVERY link emailed to a human
# (employee set-password/login link, technician job link, Stripe billing return).
# PROD: set to the live domain — https://crm.kikichat.de today, switch to
# https://crm.heykiki.de after the domain migration. It must also be on Supabase
# Auth's Redirect-URL allow-list. Locally point it at the dev server.
FRONTEND_PUBLIC_URL=http://localhost:5173

# Brevo SMTP fallback (P1.8 Phase 3 / Wave 1.2 — `email_send.py` tier 3).
# Used when an org has no OAuth + no customer SMTP, or every upstream tier
# fails. PRODUCTION VALUES MUST BE SET IN RAILWAY ENV VARS — never commit
# real credentials here. Locally these can stay blank; the chain will only
# raise if it actually reaches the Brevo tier without creds.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=
BREVO_SMTP_PASSWORD=
BREVO_SMTP_FROM_ADDRESS=no-reply@heykiki.de
BREVO_SMTP_FROM_NAME=HeyKiki
