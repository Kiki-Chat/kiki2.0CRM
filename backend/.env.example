# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# HeyKiki provisioning
MASTER_WEBHOOK_SECRET=change-me
# Shared secret for the N8N -> backend post-call webhook hop
POST_CALL_WEBHOOK_SECRET=change-me

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173

# ElevenLabs (used in later phases)
ELEVENLABS_API_KEY=

# Secret-at-rest encryption for stored SMTP/PDS credentials (REQUIRED — backend refuses to start without it).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENC_KEY=<run-python-c-from-cryptography-fernet-import-Fernet-print-Fernet-generate-key-decode>
