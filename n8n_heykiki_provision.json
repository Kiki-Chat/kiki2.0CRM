    {
      "parameters": {
        "jsCode": "// Build the POST /api/heykiki/provision body and a UNIQUE tracking id.\n// The CRM dedups on heykikiOrgId + loginEmail (409 if it already exists), so a\n// unique id per provisioning is what lets you trace a tenant end to end. The id\n// is human-readable: <company-slug>-<base36 time><random>.\nconst lead = $('Process Lead Data').first().json;\nconst ud = lead.user_data || {};\nconst company = (ud.company || ud.name || 'Kunde').toString();\nconst slug = company.toLowerCase().normalize('NFKD').replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 32) || 'org';\nconst heykikiOrgId = `${slug}-${Date.now().toString(36)}${Math.random().toString(36).slice(2, 6)}`;\n\nreturn [{\n  json: {\n    heykikiOrgId: heykikiOrgId,            // unique tenant tracking id\n    orgName: company,\n    loginEmail: ud.email,\n    loginPassword: 'changeme123',          // >= 8 chars; prompt a reset in the welcome email\n    elevenlabsAgentId: lead.agent_id,\n    adminName: ud.name || null,\n    contactEmail: ud.email || null\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
