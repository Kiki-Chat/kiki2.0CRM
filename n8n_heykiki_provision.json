        "jsCode": "// Parse the incoming lead payload into a clean shape.\n// Accepts the same body the ChatDash webhook used.\nconst root = $input.first().json;\nconst body = root.body || root;\nconst ud = body.user_data || {};\nreturn [{\n  json: {\n    agent_id: body.agent_id || ud.agent_id || null,\n    user_data: {\n      email: ud.email || body.email || null,\n      name: ud.name || body.name || null,\n      phone: ud.phone || body.phone || null,\n      company: ud.company || body.company || null\n    },\n    session_id: body.session_id || null,\n    timestamp: body.timestamp || null\n  }\n}];"
      },
